<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <h1 class="h3 mb-0 text-gray-800">
    <%= document ? 'Chỉnh sửa tài liệu' : 'Thêm tài liệu mới' %>
  </h1>
  <a href="/dashboard/document" class="btn btn-secondary btn-sm">
    <i class="fas fa-arrow-left"></i> Quay lại
  </a>
</div>

<div class="card shadow mb-4">
  <div class="card-body">
    <form action="<%= document ? '/dashboard/document/edit/' + document.id : '/dashboard/document/create' %>"
      method="POST" enctype="multipart/form-data">

      <div class="mb-3">
        <label class="form-label font-weight-bold">Tiêu đề <span class="text-danger">*</span></label>
        <input type="text" name="title" class="form-control"
          value="<%= document ? document.title : '' %>" required
          placeholder="Ví dụ: Thông báo – Công bố chỉ tiêu (KĐVN)">
      </div>

      <div class="mb-3">
        <label class="form-label font-weight-bold">Ngày công bố</label>
        <input type="date" name="published_at" class="form-control"
          value="<%= document && document.published_at ? document.published_at : '' %>">
      </div>

      <div class="mb-3">
        <label class="form-label font-weight-bold">
          File PDF <% if (!document) { %><span class="text-danger">*</span><% } %>
        </label>
        <input type="file" name="pdf_file" class="form-control" accept=".pdf"
          <%= document ? '' : 'required' %>>
        <% if (document && document.file_path) { %>
        <div class="mt-2">
          <small class="text-muted">File hiện tại: </small>
          <a href="<%= document.file_path %>" target="_blank" class="btn btn-sm btn-outline-info">
            <i class="fas fa-file-pdf"></i> Xem file PDF
          </a>
          <small class="text-muted d-block mt-1">Để trống nếu không muốn thay đổi file.</small>
        </div>
        <% } %>
      </div>

      <button type="submit" class="btn btn-primary">
        <i class="fas fa-save"></i> <%= document ? 'Cập nhật' : 'Lưu tài liệu' %>
      </button>
    </form>
  </div>
</div>
