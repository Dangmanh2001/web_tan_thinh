<section class="page-section bg-light" id="services-detail">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="section-heading text-uppercase fw-bold" style="color: #2e7d32">Dịch Vụ Chuyên Ngành</h2>
      <h3 class="section-subheading text-muted">Giải pháp kỹ thuật toàn diện – Chính xác – Kịp thời.</h3>
    </div>

    <%
      function decodeServiceHtml(html) {
        if (!html) return '';
        return String(html)
          .replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#39;/g, "'").replace(/&amp;/g, '&').replace(/&nbsp;/g, ' ')
          .replace(/&agrave;/g, 'à').replace(/&aacute;/g, 'á').replace(/&acirc;/g, 'â').replace(/&atilde;/g, 'ã')
          .replace(/&egrave;/g, 'è').replace(/&eacute;/g, 'é').replace(/&ecirc;/g, 'ê')
          .replace(/&igrave;/g, 'ì').replace(/&iacute;/g, 'í').replace(/&icirc;/g, 'î')
          .replace(/&ograve;/g, 'ò').replace(/&oacute;/g, 'ó').replace(/&ocirc;/g, 'ô').replace(/&otilde;/g, 'õ')
          .replace(/&ugrave;/g, 'ù').replace(/&uacute;/g, 'ú').replace(/&ucirc;/g, 'û')
          .replace(/&yacute;/g, 'ý').replace(/&ndash;/g, '-').replace(/&mdash;/g, '—')
          .replace(/&ldquo;/g, '"').replace(/&rdquo;/g, '"').replace(/&lsquo;/g, ''').replace(/&rsquo;/g, ''')
          .replace(/&#(\d+);/g, (_, code) => String.fromCharCode(parseInt(code)));
      }
    %>
    <div class="row" id="services-container">
      <% services.forEach((service) => { %>
        <div class="col-lg-4 col-md-6 mb-4">
          <div class="card h-100 border-0 shadow-sm service-card overflow-hidden">
            <% if (service.thumbnail) { %>
              <div class="position-relative">
                <img class="card-img-top" src="<%= service.thumbnail %>" alt="<%= service.name %>">
              </div>
            <% } %>
            <div class="card-body p-4">
              <h5 class="card-title fw-bold line-clamp-2"><%= service.name %></h5>
              <p class="card-text text-muted small line-clamp-3">
                <%
                  let svcPreview = decodeServiceHtml(service.content || service.description || '')
                    .replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
                %>
                <%= svcPreview.substring(0, 120) %><%= svcPreview.length > 120 ? '...' : '' %>
              </p>
              <a href="/services/<%= service.id %>" class="btn btn-link text-decoration-none p-0" style="color: #2e7d32; font-weight: 600">
                Chi tiết dịch vụ <i class="fas fa-arrow-right ms-1"></i>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Phân trang -->
    <% if (totalPages > 1) { %>
    <%
      const windowSize = 3;
      let startPage = Math.max(1, currentPage - Math.floor(windowSize / 2));
      let endPage = startPage + windowSize - 1;
      if (endPage > totalPages) {
        endPage = totalPages;
        startPage = Math.max(1, endPage - windowSize + 1);
      }
    %>
    <div class="d-flex justify-content-center mt-5">
      <ul class="pagination">
        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= currentPage - 1 %>">«</a>
        </li>

        <% if (startPage > 1) { %>
        <li class="page-item"><a class="page-link" href="?page=1">1</a></li>
        <% if (startPage > 2) { %>
        <li class="page-item disabled"><span class="page-link">...</span></li>
        <% } %>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %>"><%= i %></a>
        </li>
        <% } %>

        <% if (endPage < totalPages) { %>
        <% if (endPage < totalPages - 1) { %>
        <li class="page-item disabled"><span class="page-link">...</span></li>
        <% } %>
        <li class="page-item"><a class="page-link" href="?page=<%= totalPages %>"><%= totalPages %></a></li>
        <% } %>

        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= currentPage + 1 %>">»</a>
        </li>
      </ul>
    </div>
    <% } %>

  </div>
</section>

<style>
  .service-card { transition: transform 0.3s ease-in-out; border-radius: 0.75rem; }
  .service-card:hover { transform: translateY(-8px); box-shadow: 0 1rem 3rem rgba(0,0,0,.15) !important; }
  .service-card .card-img-top { height: 220px; object-fit: cover; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3rem; }
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; height: 4.5rem; }
</style>