<section class="page-section bg-light" id="services-detail">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="section-heading text-uppercase fw-bold" style="color: #2e7d32">Dịch Vụ Chuyên Ngành</h2>
      <h3 class="section-subheading text-muted">Giải pháp kỹ thuật toàn diện – Chính xác – Kịp thời.</h3>
    </div>

    <div class="row g-4">
      <% services.forEach((service, index) => { %>
        <% 
          // Xen kẽ: Card 1 (trắng), Card 2 (xanh), Card 3 (trắng)...
          let isFeatured = (index % 2 !== 0); 
        %>
        <div class="col-lg-4 col-md-6">
          <div class="card h-100 border-0 shadow-sm service-card <%= isFeatured ? 'featured' : '' %>">
            
            <div class="service-icon-box text-center py-4" style="height: 120px; display: flex; align-items: center; justify-content: center;">
              <% if(service.thumbnail) { %>
                <img src="<%= service.thumbnail %>" alt="<%= service.name %>" style="max-width: 70px; max-height: 70px; object-fit: contain;">
              <% } else { %>
                <i class="fas fa-flask fa-3x" style="<%= isFeatured ? 'color: #ffffff' : 'color: #2e7d32' %>"></i>
              <% } %>
            </div>

            <div class="card-body p-4 pt-0 d-flex flex-column">
              <h4 class="card-title fw-bold text-center mb-3 service-title <%= isFeatured ? 'text-white' : '' %>">
                <%= service.name %>
              </h4>
              
              <div class="card-text small mb-3">
                <span class="fw-bold d-block mb-1 <%= isFeatured ? 'text-white' : 'text-success' %>">Tổng quan:</span>
                <p class="description-clamp mb-0 <%= isFeatured ? 'text-light' : 'text-muted' %>">
                  <%= service.description %>
                </p>
              </div>
              
              <% if(service.content) { %>
                <div class="service-content-preview small text-justify <%= isFeatured ? 'text-light' : 'text-muted' %>">
                  <%
                    const htmlEntities = {'&nbsp;':' ','&amp;':'&','&lt;':'<','&gt;':'>','&quot;':'"','&#39;':"'",'&aacute;':'á','&agrave;':'à','&acirc;':'â','&atilde;':'ã','&auml;':'ä','&aring;':'å','&Aacute;':'Á','&Agrave;':'À','&Acirc;':'Â','&eacute;':'é','&egrave;':'è','&ecirc;':'ê','&euml;':'ë','&Eacute;':'É','&Egrave;':'È','&Ecirc;':'Ê','&iacute;':'í','&igrave;':'ì','&icirc;':'î','&Iacute;':'Í','&oacute;':'ó','&ograve;':'ò','&ocirc;':'ô','&otilde;':'õ','&ouml;':'ö','&Oacute;':'Ó','&Ocirc;':'Ô','&Otilde;':'Õ','&uacute;':'ú','&ugrave;':'ù','&ucirc;':'û','&uuml;':'ü','&Uacute;':'Ú','&yacute;':'ý','&Yacute;':'Ý','&ntilde;':'ñ','&ccedil;':'ç','&lsquo;':'\u2018','&rsquo;':'\u2019','&ldquo;':'\u201C','&rdquo;':'\u201D','&ndash;':'–','&mdash;':'—','&hellip;':'…'};
                    let cleanPreview = service.content
                      .replace(/<[^>]*>/g, ' ')
                      .replace(/&#(\d+);/g, (_, code) => String.fromCharCode(parseInt(code)))
                      .replace(/&[a-z]+;/gi, m => htmlEntities[m] || m)
                      .replace(/\s+/g, ' ')
                      .trim();
                  %>
                  <%= cleanPreview %>
                </div>
              <% } %>
            </div>

            <div class="card-footer bg-transparent border-0 pb-4 text-center mt-auto">
              <a href="/services/<%= service.id %>" class="btn <%= isFeatured ? 'btn-light text-success' : 'btn-outline-success' %> btn-sm px-4 shadow-sm fw-bold rounded-pill">
                Chi tiết dịch vụ
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Phân trang -->
    <% if (totalPages > 1) { %>
    <%
      const windowSize = 3;
      let startPage = Math.max(1, currentPage - Math.floor(windowSize / 2));
      let endPage = startPage + windowSize - 1;
      if (endPage > totalPages) {
        endPage = totalPages;
        startPage = Math.max(1, endPage - windowSize + 1);
      }
    %>
    <div class="d-flex justify-content-center mt-5">
      <ul class="pagination">
        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= currentPage - 1 %>">«</a>
        </li>

        <% if (startPage > 1) { %>
        <li class="page-item"><a class="page-link" href="?page=1">1</a></li>
        <% if (startPage > 2) { %>
        <li class="page-item disabled"><span class="page-link">...</span></li>
        <% } %>
        <% } %>

        <% for (let i = startPage; i <= endPage; i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %>"><%= i %></a>
        </li>
        <% } %>

        <% if (endPage < totalPages) { %>
        <% if (endPage < totalPages - 1) { %>
        <li class="page-item disabled"><span class="page-link">...</span></li>
        <% } %>
        <li class="page-item"><a class="page-link" href="?page=<%= totalPages %>"><%= totalPages %></a></li>
        <% } %>

        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= currentPage + 1 %>">»</a>
        </li>
      </ul>
    </div>
    <% } %>

  </div>
</section>

<style>
/* Đảm bảo các Card đều nhau */
.service-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 2.8em;
    line-height: 1.4;
}

.description-clamp {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 3em;
}

.service-content-preview {
    display: -webkit-box;
    -webkit-line-clamp: 3; /* Giới hạn 3 dòng cho phần nội dung chi tiết ở trang chủ */
    -webkit-box-orient: vertical;  
    overflow: hidden;
    line-height: 1.6;
}

.service-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-radius: 1rem;
}

.service-card.featured {
    background-color: #2e7d32;
}

.service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 1rem 3rem rgba(0,0,0,.175)!important;
}

/* Tùy chỉnh màu nút khi ở trong card xanh */
.service-card.featured .btn-light {
    color: #2e7d32 !important;
}
</style>