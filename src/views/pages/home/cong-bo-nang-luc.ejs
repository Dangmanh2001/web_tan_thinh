<section class="page-section" id="cong-bo-nang-luc" style="padding-top: 100px;">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="section-heading text-uppercase" style="color: #2e7d32">Công bố năng lực</h2>
      <h3 class="section-subheading text-muted">
        Các tài liệu công bố năng lực, chỉ tiêu thí nghiệm của công ty
      </h3>
    </div>

    <% if (documents.length === 0) { %>
    <div class="text-center text-muted py-5">
      <i class="fas fa-file-pdf fa-3x mb-3" style="color: #ccc;"></i>
      <p>Chưa có tài liệu nào.</p>
    </div>
    <% } else { %>

    <!-- Tabs điều hướng -->
    <ul class="nav nav-tabs mb-4" id="docTabs" role="tablist">
      <% documents.forEach((doc, index) => { %>
      <li class="nav-item" role="presentation">
        <button
          class="nav-link <%= index === 0 ? 'active' : '' %>"
          id="tab-<%= doc.id %>"
          data-bs-toggle="tab"
          data-bs-target="#pane-<%= doc.id %>"
          type="button" role="tab">
          <i class="fas fa-file-pdf me-1" style="color: #e53935;"></i>
          <%= doc.title %>
          <% if (doc.published_at) { %>
          <small class="text-muted ms-1">(<%= new Date(doc.published_at).toLocaleDateString('vi-VN') %>)</small>
          <% } %>
        </button>
      </li>
      <% }) %>
    </ul>

    <!-- Nội dung tab -->
    <div class="tab-content" id="docTabContent">
      <% documents.forEach((doc, index) => { %>
      <div
        class="tab-pane fade <%= index === 0 ? 'show active' : '' %>"
        id="pane-<%= doc.id %>"
        role="tabpanel">

        <div class="card shadow-sm">
          <div class="card-header d-flex justify-content-between align-items-center" style="background:#f8f9fa;">
            <span class="fw-bold"><i class="fas fa-file-pdf me-2" style="color:#e53935;"></i><%= doc.title %></span>
            <a href="<%= doc.file_path %>" download class="btn btn-sm btn-outline-success">
              <i class="fas fa-download me-1"></i> Tải về
            </a>
          </div>
          <div class="card-body p-0">
            <iframe
              src="<%= doc.file_path %>"
              style="width:100%; height:780px; border:none;"
              title="<%= doc.title %>">
              <p>Trình duyệt của bạn không hỗ trợ hiển thị PDF.
                <a href="<%= doc.file_path %>">Nhấn đây để tải về</a>.
              </p>
            </iframe>
          </div>
        </div>

      </div>
      <% }) %>
    </div>

    <!-- Phân trang -->
    <% if (totalPages > 1) { %>
    <%
      const windowSize = 3;
      let startPage = Math.max(1, currentPage - Math.floor(windowSize / 2));
      let endPage = startPage + windowSize - 1;
      if (endPage > totalPages) { endPage = totalPages; startPage = Math.max(1, endPage - windowSize + 1); }
    %>
    <div class="d-flex justify-content-center mt-5">
      <ul class="pagination">
        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= currentPage - 1 %>">«</a>
        </li>
        <% if (startPage > 1) { %>
        <li class="page-item"><a class="page-link" href="?page=1">1</a></li>
        <% if (startPage > 2) { %><li class="page-item disabled"><span class="page-link">...</span></li><% } %>
        <% } %>
        <% for (let i = startPage; i <= endPage; i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %>"><%= i %></a>
        </li>
        <% } %>
        <% if (endPage < totalPages) { %>
        <% if (endPage < totalPages - 1) { %><li class="page-item disabled"><span class="page-link">...</span></li><% } %>
        <li class="page-item"><a class="page-link" href="?page=<%= totalPages %>"><%= totalPages %></a></li>
        <% } %>
        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= currentPage + 1 %>">»</a>
        </li>
      </ul>
    </div>
    <% } %>

    <% } %>
  </div>
</section>
