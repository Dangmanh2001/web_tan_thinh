<section class="page-section bg-light" id="news">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="section-heading text-uppercase" style="color: #2e7d32">Tin Tức & Sự Kiện</h2>
      <h3 class="section-subheading text-muted">Cập nhật hoạt động mới nhất tại Tân Thịnh.</h3>
    </div>

    <div class="row" id="news-container">
      <% if (posts && posts.length > 0) { %>
        <% posts.forEach((post, index) => { %>
          <div class="col-lg-4 col-md-6 mb-4 <%= index >= 3 ? 'd-none extra-post' : '' %>">
            <div class="card h-100 border-0 shadow-sm overflow-hidden">
              <div class="position-relative">
                <img class="card-img-top" src="<%= post.thumbnail ? '/assets/img/posts/' + post.thumbnail : 'https://via.placeholder.com/800x450' %>" alt="<%= post.title %>" />
                <div class="badge bg-success position-absolute start-0 top-0 m-3 px-3 py-2">
                  <%= post.Category ? post.Category.name : 'Tin tức' %>
                </div>
              </div>
              <div class="card-body p-4">
                <div class="text-muted small mb-2">
                  <i class="far fa-calendar-alt me-1"></i> 
                  <%= new Date(post.created_at).toLocaleDateString('vi-VN') %>
                </div>
                <h5 class="card-title fw-bold line-clamp-2"><%= post.title %></h5>
                <p class="card-text text-muted small line-clamp-3">
                  <% let cleanContent = post.content.replace(/#{2,3}\s/g, '').replace(/\n/g, ' '); %>
                  <%= cleanContent.substring(0, 120) %>...
                </p>
                <a href="/news/<%= post.slug %>" class="btn btn-link text-decoration-none p-0" style="color: #2e7d32; font-weight: 600">
                  Xem chi tiết <i class="fas fa-arrow-right ms-1"></i>
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12 text-center py-5"><p class="text-muted">Đang cập nhật...</p></div>
      <% } %>
    </div>

    <% if (posts && posts.length > 3) { %>
      <div class="text-center mt-5" id="view-all-container">
        <button id="btn-view-all" class="btn btn-outline-dark btn-xl text-uppercase">
          Xem tất cả tin tức
        </button>
      </div>
    <% } %>
  </div>
</section>

<script>
  // Xử lý sự kiện bấm nút Xem tất cả
  document.getElementById('btn-view-all')?.addEventListener('click', function() {
    // Tìm tất cả các bài viết đang bị ẩn
    const extraPosts = document.querySelectorAll('.extra-post');
    extraPosts.forEach(post => {
      post.classList.remove('d-none'); // Hiển thị bài viết
      post.classList.add('animate__animated', 'animate__fadeIn'); // Thêm hiệu ứng nếu muốn
    });
    
    // Ẩn nút "Xem tất cả" sau khi đã hiện hết bài
    document.getElementById('view-all-container').classList.add('d-none');
  });
</script>

<style>
  /* Giữ nguyên các Style cũ của bạn */
  .card { transition: transform 0.3s ease-in-out; }
  .card:hover { transform: translateY(-10px); }
  .card-img-top { height: 220px; object-fit: cover; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3rem; }
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; height: 4.5rem; }
</style>