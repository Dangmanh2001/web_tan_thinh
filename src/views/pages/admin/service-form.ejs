<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <h1 class="h3 mb-0 text-gray-800"><%= service ? 'Sửa dịch vụ' : 'Thêm dịch vụ' %></h1>
  <a href="/dashboard/service" class="btn btn-secondary btn-sm">
    <i class="fas fa-arrow-left"></i> Quay lại
  </a>
</div>

<div class="card shadow mb-4">
  <div class="card-body">
    <form action="<%= service ? '/dashboard/service/edit/' + service.id : '/dashboard/service/create' %>" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Tên dịch vụ <span class="text-danger">*</span></label>
        <input type="text" class="form-control" name="name" value="<%= service ? service.name : '' %>" required>
      </div>

      <div class="form-group">
        <label>Mô tả ngắn</label>
        <textarea class="form-control" name="description" rows="3"><%= service ? service.description : '' %></textarea>
      </div>

      <div class="form-group">
        <label>Nội dung</label>
        <div class="mb-2">
          <button type="button" class="btn btn-sm btn-outline-primary" onclick="document.getElementById('imgPickerSvc').click()">
            <i class="fas fa-image"></i> Chèn ảnh vào nội dung
          </button>
          <input type="file" id="imgPickerSvc" accept="image/*" multiple style="display:none" onchange="uploadImagesSvc(this.files)">
          <span id="uploadStatusSvc" class="ml-2 small text-muted"></span>
        </div>
        <textarea id="contentEditor" name="content" rows="6"><%= service ? service.content : '' %></textarea>
      </div>

      <div class="form-group">
        <label>Ảnh thumbnail</label><br>
        <% if (service && service.thumbnail) { %>
        <img src="<%= service.thumbnail %>" alt="" style="width:100px; height:100px; object-fit:cover; border-radius:4px; margin-bottom:8px; display:block;">
        <% } %>
        <input type="file" class="form-control-file" name="thumbnail" accept="image/*">
        <small class="text-muted">Để trống nếu không muốn thay đổi ảnh</small>
      </div>

      <button type="submit" class="btn btn-primary">
        <i class="fas fa-save"></i> Lưu
      </button>
    </form>
  </div>
</div>

<script src="https://cdn.ckeditor.com/4.22.1/full/ckeditor.js"></script>
<script>
  CKEDITOR.replace('contentEditor');

  document.querySelector('form').addEventListener('submit', function () {
    for (let instance in CKEDITOR.instances) {
      CKEDITOR.instances[instance].updateElement();
    }
  });

  async function uploadImagesSvc(files) {
    const status = document.getElementById('uploadStatusSvc');
    status.textContent = 'Đang tải lên...';
    let count = 0;
    for (const file of files) {
      const form = new FormData();
      form.append('upload', file);
      try {
        const res = await fetch('/dashboard/upload-image', { method: 'POST', body: form });
        const data = await res.json();
        if (data.success && data.url) {
          CKEDITOR.instances['contentEditor'].insertHtml(
            `<img src="${data.url}" style="max-width:100%; height:auto; margin:8px 0;">`
          );
          count++;
        }
      } catch (e) {
        console.error(e);
      }
    }
    status.textContent = count > 0 ? `✓ Đã chèn ${count} ảnh` : '✗ Tải lên thất bại';
    setTimeout(() => { status.textContent = ''; }, 3000);
    document.getElementById('imgPickerSvc').value = '';
  }
</script>