<div class="d-sm-flex align-items-center justify-content-between mb-4">
  <h1 class="h3 mb-0 text-gray-800"><%= post ? 'Sửa bài viết' : 'Thêm bài viết' %></h1>
  <a href="/dashboard/news" class="btn btn-secondary btn-sm">
    <i class="fas fa-arrow-left"></i> Quay lại
  </a>
</div>

<div class="card shadow mb-4">
  <div class="card-body">
    <form action="<%= post ? '/dashboard/news/edit/' + post.id : '/dashboard/news/create' %>" method="POST" enctype="multipart/form-data">

      <div class="form-group">
        <label>Tiêu đề <span class="text-danger">*</span></label>
        <input type="text" class="form-control" name="title" value="<%= post ? post.title : '' %>" required>
      </div>

      <div class="form-group">
        <label>Danh mục</label>
        <select class="form-control" name="category_id">
          <option value="">-- Chọn danh mục --</option>
          <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>" <%= post && post.category_id == cat.id ? 'selected' : '' %>>
            <%= cat.name %>
          </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Nội dung</label>
        <div class="mb-2">
          <button type="button" class="btn btn-sm btn-outline-primary" onclick="document.getElementById('imgPicker').click()">
            <i class="fas fa-image"></i> Chèn ảnh vào nội dung
          </button>
          <input type="file" id="imgPicker" accept="image/*" multiple style="display:none" onchange="uploadImages(this.files)">
          <span id="uploadStatus" class="ml-2 small text-muted"></span>
        </div>
        <textarea id="newsContent" name="content" rows="8"><%= post ? post.content : '' %></textarea>
      </div>

      <div class="form-group">
        <label>Ảnh thumbnail</label><br>
        <% if (post && post.thumbnail) { %>
        <img src="<%= post.thumbnail %>" alt="" style="width:100px; height:100px; object-fit:cover; border-radius:4px; margin-bottom:8px; display:block;">
        <% } %>
        <input type="file" class="form-control-file" name="thumbnail" accept="image/*">
        <small class="text-muted">Để trống nếu không muốn thay đổi ảnh</small>
      </div>

      <button type="submit" class="btn btn-primary">
        <i class="fas fa-save"></i> Lưu
      </button>
    </form>
  </div>
</div>

<script src="https://cdn.ckeditor.com/4.22.1/full/ckeditor.js"></script>
<script>
  CKEDITOR.replace('newsContent');

  document.querySelector('form').addEventListener('submit', function () {
    for (let instance in CKEDITOR.instances) {
      CKEDITOR.instances[instance].updateElement();
    }
  });

  async function uploadImages(files) {
    const status = document.getElementById('uploadStatus');
    status.textContent = 'Đang tải lên...';
    let count = 0;
    for (const file of files) {
      const form = new FormData();
      form.append('upload', file);
      try {
        const res = await fetch('/dashboard/upload-image', { method: 'POST', body: form });
        const data = await res.json();
        if (data.success && data.url) {
          CKEDITOR.instances['newsContent'].insertHtml(
            `<img src="${data.url}" style="max-width:100%; height:auto; margin:8px 0;">`
          );
          count++;
        }
      } catch (e) {
        console.error(e);
      }
    }
    status.textContent = count > 0 ? `✓ Đã chèn ${count} ảnh` : '✗ Tải lên thất bại';
    setTimeout(() => { status.textContent = ''; }, 3000);
    document.getElementById('imgPicker').value = '';
  }
</script>